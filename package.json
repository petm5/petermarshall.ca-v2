{
	"name": "petermarshall.ca-v2",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"build-ipfs": "node scripts/generate-ipfs.js",
		"build-ipni": "node --import=tsx scripts/generate-ipni.ts",
		"build-ipfs-worker": "node --import=tsx scripts/build-ipfs-worker.ts",
		"build-all": "vite build && node scripts/generate-ipfs.js && node --import=tsx scripts/generate-ipni.ts && node --import=tsx scripts/build-ipfs-worker.ts",
		"ipni-provide": "node --import=tsx scripts/provide-ipni.ts",
		"update-dnslink": "node --import=tsx scripts/update-dnslink.ts"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260214.0",
		"@libp2p/crypto": "^5.1.13",
		"@libp2p/interface": "^3.1.0",
		"@libp2p/peer-id": "^6.0.4",
		"@multiformats/multiaddr": "^13.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.2.0",
		"blockstore-core": "^6.1.2",
		"cloudflare": "^5.2.0",
		"esbuild": "^0.27.3",
		"glob": "^13.0.0",
		"ipfs-unixfs-importer": "^16.0.2",
		"ipns": "^10.1.3",
		"js-ipni": "github:petm5/js-ipni#9272bf8e1dec0140afa2a71bb02e26624598b041",
		"mdsvex": "^0.12.6",
		"multiformats": "^13.4.2",
		"svelte": "^5.54.1",
		"tsx": "^4.21.0",
		"vite": "^8.0.0"
	}
